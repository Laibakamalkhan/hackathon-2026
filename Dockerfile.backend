# -------------------------------------------------
# 1️⃣ Build stage
# -------------------------------------------------
FROM python:3.12-slim AS build

WORKDIR /app/ai_seekho_backend
ENV PYTHONPATH=/app/ai_seekho_backend

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc libssl-dev && \
    rm -rf /var/lib/apt/lists/*

COPY ai_seekho_backend/requirements.txt requirements.txt

RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

COPY ai_seekho_backend/ ./ai_seekho_backend/

# -------------------------------------------------
# 2️⃣ Runtime stage
# -------------------------------------------------
FROM python:3.12-slim

WORKDIR /app

COPY --from=build /install /usr/local
COPY --from=build /app/ai_seekho_backend ./ai_seekho_backend

EXPOSE 8080

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]