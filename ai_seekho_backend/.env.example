# ============================================================
# AI Seekho Backend — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#
#   Windows:  copy .env.example .env
#   Linux/Mac: cp .env.example .env
#
# NEVER commit .env or your Firebase Admin JSON to version control.
# Both are listed in .gitignore.
# ============================================================


# ------------------------------------------------------------
# Google Gemini API
# ------------------------------------------------------------
# Obtain from: https://aistudio.google.com/app/apikey
# Required for CoordinatorAgent, ExecutorAgent, GuardianAgent.
# Model used: gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here


# ------------------------------------------------------------
# Google Maps Platform
# ------------------------------------------------------------
# Obtain from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Distance Matrix API, Geocoding API.
# Used for distance calculation in the 9-factor matching algorithm.
# Optional — if omitted, straight-line (Haversine) distance is used.
MAPS_API_KEY=your-maps-api-key-here


# ------------------------------------------------------------
# Firebase Admin SDK
# ------------------------------------------------------------
# Path to your service-account credentials JSON file.
# Download from: Firebase Console → Project Settings → Service Accounts
#   → Generate new private key
#
# Can be an absolute path or relative to ai_seekho_backend/:
#   FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json
#   FIREBASE_CREDENTIALS_PATH=C:/secrets/my-project-firebase.json
#
# Required for Firestore reads/writes (bookings, traces, providers).
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json


# ------------------------------------------------------------
# Firebase Project ID (optional)
# ------------------------------------------------------------
# Usually auto-detected from the credentials JSON.
# Only set this if you are using Application Default Credentials
# instead of a service-account file.
# FIREBASE_PROJECT_ID=your-project-id


# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Python logging level for the FastAPI app.
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO


# ------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------
# Comma-separated list of allowed origins.
# Default: http://localhost:* for local development.
# DO NOT use allow_origins=["*"] or CORS_ORIGINS=* in production.
CORS_ORIGINS=http://localhost:*
